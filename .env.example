# Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# MVP MODE - No API keys required for the current implementation
# ============================================================================
# The MVP runs entirely locally using sample data files.
# Only the CultureWebAgent is active.

# ============================================================================
# Future Service API Keys (not used in MVP)
# ============================================================================

# Browserbase - for live web browsing
# BROWSERBASE_API_KEY=your_browserbase_api_key_here

# Kalshi - for market data and trading
# KALSHI_API_KEY_ID=your_kalshi_api_key_id_here
# KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi/private/key
# KALSHI_ENV=demo  # demo or production

# Fetch.ai - for agent deployment
# FETCH_API_KEY=your_fetch_api_key_here

# LLM Service (OpenAI, Anthropic, etc.) - for enhanced decision agent
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================================
# Trading Configuration (not used in MVP)
# ============================================================================

# Trading mode: dry_run, demo, or live
TRADE_MODE=dry_run

# Enable live trading (must be explicitly set to true for real trades)
ENABLE_LIVE_TRADING=false

# Risk management settings
MAX_ORDER_COUNT=1
MAX_ORDER_DOLLARS=5
MIN_CONFIDENCE=0.70
MIN_EDGE=0.05

# ============================================================================
# Compression Configuration
# ============================================================================

# Token budget for compressed context (default: 3000)
# TOKEN_BUDGET=3000

# Deduplication threshold (default: 0.85)
# DEDUP_THRESHOLD=0.85
