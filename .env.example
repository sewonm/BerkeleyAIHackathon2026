# ── Browserbase ───────────────────────────────────────────────────────────
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ── Fetch AI / Agentverse ─────────────────────────────────────────────────
# AGENT_SEED: any string — keeps agent address stable across restarts
# Copy printed agent address into Agentverse registration
AGENT_SEED=signalforge-market-research-agent-v1-seed
AGENT_PORT=8001

# ── Backend ───────────────────────────────────────────────────────────────
# For local dev: http://localhost:8000
# For demo with ngrok: https://your-ngrok-url.ngrok.io
BACKEND_URL=http://localhost:8000

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── LLM (decision agent) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Kalshi (optional — for live market prices) ────────────────────────────
KALSHI_ENV=demo
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# ── Trading mode (never set ENABLE_LIVE_TRADING=true for demo) ────────────
TRADE_MODE=dry_run
ENABLE_LIVE_TRADING=false
